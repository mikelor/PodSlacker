@page "/job/{JobId}"
@rendermode InteractiveServer
@inject PodSlackerApiClient ApiClient
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>@PageTitleText — PodSlacker</PageTitle>

<div class="row justify-content-center mt-2">
    <div class="col-lg-6 col-md-8">

        <div class="d-flex align-items-center gap-2 mb-4 flex-wrap">
            <a href="/" class="btn btn-outline-secondary btn-sm">← New job</a>
            <span class="ps-job-id">@JobId</span>
            <button class="ps-copy-btn @(copied ? "copied" : "")"
                    @onclick="CopyUrlAsync" title="Copy job URL">
                @if (copied)
                {
                    <span>✓ Copied!</span>
                }
                else
                {
                    <span>⎘ Copy URL</span>
                }
            </button>
        </div>

        @if (status is null && !loadFailed)
        {
            <div class="d-flex align-items-center gap-3 p-4">
                <div class="spinner-border text-primary" role="status"></div>
                <span class="fs-5 text-muted">Loading job status…</span>
            </div>
        }
        else if (loadFailed)
        {
            <div class="alert alert-danger">
                <strong>Could not load job.</strong> @errorMessage
                <div class="mt-2">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="RetryAsync">Retry</button>
                </div>
            </div>
        }
        else if (status is not null)
        {
            <div class="card shadow-sm mb-3">
                <div class="card-body p-4">

                    @if (!string.IsNullOrEmpty(status.Title))
                    {
                        <p class="font-mono small mb-2" style="color: var(--ps-accent2);">🎬 @status.Title</p>
                    }
                    <h2 class="h4 mb-1">
                        @StatusIcon <span class="text-accent fw-semibold">@StatusLabel</span>
                    </h2>
                    <p class="text-muted mb-3">@status.Message</p>

                    @if (status.Status is "Queued" or "Running")
                    {
                        <div class="progress mb-2" style="height: 1.5rem;" role="progressbar"
                             aria-valuenow="@status.Percent" aria-valuemin="0" aria-valuemax="100">
                            <div class="progress-bar progress-bar-striped progress-bar-animated"
                                 style="width: @(status.Percent)%">
                                @if (status.Percent > 8)
                                {
                                    <span>@status.Percent%</span>
                                }
                            </div>
                        </div>
                        <p class="text-muted small mb-0">Checking for updates every 5 seconds…</p>
                    }

                    @if (status.Status == "Completed")
                    {
                        <div class="d-flex flex-wrap gap-2">
                            <a class="btn btn-success" href="@DownloadUrl" target="_blank">
                                ⬇️ Download Your SlackCast
                            </a>
                            @if (!string.IsNullOrEmpty(status.GitHubPagesUrl))
                            {
                                <a class="btn btn-outline-secondary" href="@status.GitHubPagesUrl"
                                   target="_blank" rel="noopener">
                                    🌐 View on GitHub Pages
                                </a>
                            }
                        </div>
                    }

                    @if (status.Status == "Failed")
                    {
                        <div class="alert alert-danger mb-0 mt-2">
                            <strong>Pipeline error:</strong> @status.Error
                        </div>
                    }

                </div>
            </div>

            @if (!string.IsNullOrEmpty(status.VideoUrl))
            {
                <p class="text-muted small">
                    Source: <a href="@status.VideoUrl" target="_blank" rel="noopener"
                               style="color: var(--ps-accent);">@status.VideoUrl</a>
                </p>
            }
        }

    </div>
</div>

@code {
    [Parameter] public string JobId { get; set; } = "";

    private JobStatusDto? status;
    private bool          loadFailed;
    private string?       errorMessage;
    private bool          copied;
    private PeriodicTimer? timer;
    private CancellationTokenSource cts = new();

    private string DownloadUrl => string.IsNullOrEmpty(status?.Title)
        ? $"/download/{JobId}"
        : $"/download/{JobId}?title={Uri.EscapeDataString(status.Title)}";

    private string PageTitleText => status switch
    {
        null                                         => "Loading…",
        { Title: { Length: > 0 } t }                => $"{StatusIcon} {t}",
        _                                            => $"{StatusIcon} Job {StatusLabel}",
    };

    private string StatusIcon => status?.Status switch
    {
        "Queued"    => "⏳",
        "Running"   => "⚙️",
        "Completed" => "✅",
        "Failed"    => "❌",
        _           => "❓",
    };

    private string StatusLabel => status?.Status switch
    {
        "Queued"    => "Queued",
        "Running"   => "Running",
        "Completed" => "Completed",
        "Failed"    => "Failed",
        _           => status?.Status ?? "Unknown",
    };

    protected override async Task OnInitializedAsync()
    {
        await PollOnceAsync();

        if (status?.Status is not ("Completed" or "Failed"))
            _ = PollLoopAsync();
    }

    private async Task PollLoopAsync()
    {
        timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        try
        {
            while (await timer.WaitForNextTickAsync(cts.Token))
            {
                await PollOnceAsync();
                await InvokeAsync(StateHasChanged);

                if (status?.Status is "Completed" or "Failed")
                    break;
            }
        }
        catch (OperationCanceledException) { /* component disposed */ }
    }

    private async Task PollOnceAsync()
    {
        try
        {
            status       = await ApiClient.GetJobStatusAsync(JobId, cts.Token);
            loadFailed   = false;
            errorMessage = null;
        }
        catch (OperationCanceledException) { /* swallow */ }
        catch (Exception ex)
        {
            loadFailed   = true;
            errorMessage = ex.Message;
        }
    }

    private async Task RetryAsync()
    {
        loadFailed = false;
        await PollOnceAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task CopyUrlAsync()
    {
        string url = Nav.ToAbsoluteUri($"/job/{JobId}").ToString();
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", url);
        copied = true;
        StateHasChanged();
        // Reset label after 2 seconds
        await Task.Delay(2000);
        copied = false;
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        await cts.CancelAsync();
        cts.Dispose();
        timer?.Dispose();
    }
}
