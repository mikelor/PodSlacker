@page "/batch"
@rendermode InteractiveServer
@inject PodSlackerApiClient ApiClient
@implements IAsyncDisposable

<PageTitle>Batch — PodSlacker</PageTitle>

<div class="row justify-content-center mt-2">
    <div class="col-lg-8">

        <!-- Header -->
        <div class="d-flex align-items-center gap-3 mb-4 flex-wrap">
            <a href="/" class="btn btn-outline-secondary btn-sm">← New job</a>
            <span class="ps-section-label mb-0">
                Batch &nbsp;·&nbsp; @jobIds.Count job@(jobIds.Count == 1 ? "" : "s")
            </span>
            @if (AllDone)
            {
                <span class="ps-badge ps-badge-completed ms-auto">All done ✓</span>
            }
            else
            {
                <span class="text-muted small ms-auto">Refreshing every 5 s…</span>
            }
        </div>

        <!-- Summary pills -->
        @if (jobs.Count > 0)
        {
            int completed = jobs.Count(j => j.Status == "Completed");
            int running   = jobs.Count(j => j.Status is "Running" or "Queued");
            int failed    = jobs.Count(j => j.Status == "Failed");

            <div class="d-flex gap-2 mb-4 flex-wrap">
                @if (completed > 0)
                {
                    <span class="ps-badge ps-badge-completed">@completed completed</span>
                }
                @if (running > 0)
                {
                    <span class="ps-badge ps-badge-running">@running running</span>
                }
                @if (failed > 0)
                {
                    <span class="ps-badge ps-badge-failed">@failed failed</span>
                }
            </div>
        }

        <!-- Loading skeleton -->
        @if (jobs.Count == 0 && !loaded)
        {
            <div class="d-flex align-items-center gap-3 p-4">
                <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                <span class="text-muted">Loading jobs…</span>
            </div>
        }

        <!-- Job cards -->
        <div class="d-flex flex-column gap-3">
            @foreach (var job in jobs)
            {
                <div class="card shadow-sm ps-batch-card">
                    <div class="card-body p-3">

                        <!-- Row 1: badge + title + detail link -->
                        <div class="d-flex align-items-start gap-2 flex-wrap mb-1">
                            <span class="@BadgeClass(job.Status) flex-shrink-0">@StatusIcon(job.Status)</span>
                            <span class="ps-batch-title flex-fill text-truncate"
                                  title="@(job.Title ?? job.VideoUrl)">
                                @(string.IsNullOrEmpty(job.Title) ? TruncateUrl(job.VideoUrl) : job.Title)
                            </span>
                            <a href="/job/@job.Id" class="btn btn-sm btn-outline-secondary flex-shrink-0">
                                Details →
                            </a>
                        </div>

                        <!-- Progress bar (running / queued) -->
                        @if (job.Status is "Running" or "Queued")
                        {
                            <div class="progress mb-1" style="height: 0.5rem;" role="progressbar"
                                 aria-valuenow="@job.Percent" aria-valuemin="0" aria-valuemax="100">
                                <div class="progress-bar progress-bar-striped progress-bar-animated"
                                     style="width: @(job.Percent)%"></div>
                            </div>
                            <p class="text-muted small mb-0" style="font-size: 0.78rem;">
                                @job.Percent% &nbsp;·&nbsp; @job.Message
                            </p>
                        }

                        <!-- Actions (completed) -->
                        @if (job.Status == "Completed")
                        {
                            <div class="d-flex gap-2 mt-2 flex-wrap">
                                <a class="btn btn-sm btn-success"
                                   href="/api/jobs/@job.Id/page" target="_blank">
                                    ⬇️ Download
                                </a>
                                @if (!string.IsNullOrEmpty(job.GitHubPagesUrl))
                                {
                                    <a class="btn btn-sm btn-outline-secondary"
                                       href="@job.GitHubPagesUrl" target="_blank" rel="noopener">
                                        🌐 GitHub Pages
                                    </a>
                                }
                            </div>
                        }

                        <!-- Error (failed) -->
                        @if (job.Status == "Failed" && !string.IsNullOrEmpty(job.Error))
                        {
                            <p class="small text-danger mb-0 mt-1" style="font-size: 0.78rem;">
                                @job.Error
                            </p>
                        }

                    </div>
                </div>
            }
        </div>

    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "jobs")]
    public string? JobsParam { get; set; }

    private List<string>       jobIds = [];
    private List<JobStatusDto> jobs   = [];
    private bool               loaded;
    private PeriodicTimer?     timer;
    private CancellationTokenSource cts = new();

    private bool AllDone => loaded && jobs.Count > 0
        && jobs.All(j => j.Status is "Completed" or "Failed");

    protected override async Task OnInitializedAsync()
    {
        jobIds = (JobsParam ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Distinct()
            .ToList();

        await PollOnceAsync();

        if (!AllDone)
            _ = PollLoopAsync();
    }

    private async Task PollLoopAsync()
    {
        timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
        try
        {
            while (await timer.WaitForNextTickAsync(cts.Token))
            {
                await PollOnceAsync();
                await InvokeAsync(StateHasChanged);

                if (AllDone) break;
            }
        }
        catch (OperationCanceledException) { /* disposed */ }
    }

    private async Task PollOnceAsync()
    {
        var updated = new List<JobStatusDto>(jobIds.Count);
        foreach (var id in jobIds)
        {
            try
            {
                updated.Add(await ApiClient.GetJobStatusAsync(id, cts.Token));
            }
            catch (OperationCanceledException) { return; }
            catch
            {
                // Keep the last known state for this job if the poll fails.
                var existing = jobs.FirstOrDefault(j => j.Id == id);
                if (existing is not null) updated.Add(existing);
            }
        }
        jobs   = updated;
        loaded = true;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────

    private static string BadgeClass(string status) => status switch
    {
        "Queued"    => "ps-badge ps-badge-queued",
        "Running"   => "ps-badge ps-badge-running",
        "Completed" => "ps-badge ps-badge-completed",
        "Failed"    => "ps-badge ps-badge-failed",
        _           => "ps-badge ps-badge-queued",
    };

    private static string StatusIcon(string status) => status switch
    {
        "Queued"    => "⏳ Queued",
        "Running"   => "⚙️ Running",
        "Completed" => "✅ Done",
        "Failed"    => "❌ Failed",
        _           => status,
    };

    private static string TruncateUrl(string url)
    {
        if (url.Length <= 55) return url;
        return url[..52] + "…";
    }

    public async ValueTask DisposeAsync()
    {
        await cts.CancelAsync();
        cts.Dispose();
        timer?.Dispose();
    }
}
